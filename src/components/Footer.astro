---
import NewsletterSignup from './NewsletterSignup.astro';
const year = new Date().getFullYear();
---
<footer class="mt-auto border-t border-brand-border/50 bg-brand-surface/30 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-lg bg-brand-cyan/20 border border-brand-cyan/40 flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
            </svg>
          </div>
          <span class="font-display font-bold text-white">AI<span class="text-brand-cyan">Tool</span>Spott</span>
        </div>
        <p class="text-brand-dim text-sm leading-relaxed">
          Honest AI tool reviews. No hype, no fluff — just real comparisons and clear verdicts.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-3">Content</h4>
        <ul class="space-y-2 text-sm">
          {[
            { href: '/',        label: 'Latest Reviews' },
            { href: '/privacy/', label: 'Privacy Policy' },
            ].map(({ href, label }) => (
            <li>
              <a href={href} class="text-brand-dim hover:text-brand-cyan transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <NewsletterSignup variant="footer" />
      </div>

      <!-- Social -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-3">Follow</h4>
        <div class="flex gap-3">
          <a
            href="https://www.youtube.com/@AIToolSpott"
            target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 px-3 py-2 rounded-lg bg-brand-surface border border-brand-border text-brand-dim hover:text-brand-cyan hover:border-brand-cyan/30 transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            EN
          </a>
          <a
            href="https://www.youtube.com/@IAToolsDiario"
            target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 px-3 py-2 rounded-lg bg-brand-surface border border-brand-border text-brand-dim hover:text-purple-400 hover:border-purple-400/30 transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            ES
          </a>
        </div>
      </div>
    </div>

    <div class="pt-6 border-t border-brand-border/50 flex flex-col sm:flex-row justify-between gap-2 text-xs text-brand-dim">
      <p>© {year} AIToolSpott. All rights reserved.</p>
      <p>
        Some links are affiliate links. We may earn a commission at no extra cost to you.
        <a href="/privacy/" class="hover:text-brand-cyan transition-colors">Privacy Policy</a>
      </p>
    </div>
  </div>
</footer>
