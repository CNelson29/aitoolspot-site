---
interface Props {
  title:         string;
  slug:          string;
  excerpt:       string;
  date:          string;
  type:          string;
  rating?:       number;
  tags?:         string[];
  affiliate_link?: string;
}
const { title, slug, excerpt, date, type, rating, tags = [] } = Astro.props;

const badge = {
  review:     { cls: 'badge-review',     label: 'Review' },
  comparison: { cls: 'badge-comparison', label: 'Comparison' },
  guide:      { cls: 'badge-guide',      label: 'Guide' },
  article:    { cls: 'badge-article',    label: 'Article' },
}[type] ?? { cls: 'badge-article', label: 'Article' };

const grad = `grad-${type}`;

function stars(r: number) {
  const full = Math.floor(r / 2);
  const half = r % 2 >= 1 ? 1 : 0;
  const empty = 5 - full - half;
  return '★'.repeat(full) + (half ? '⯨' : '') + '☆'.repeat(empty);
}

const dateFormatted = new Date(date).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});
---
<a href={`/${slug}/`} class="card-glass group block overflow-hidden no-underline">
  <!-- Gradient header strip -->
  <div class={`h-2 w-full ${grad} opacity-80`}></div>
  <div class={`h-28 ${grad} flex items-end p-4 relative overflow-hidden`}>
    <div class="absolute inset-0 opacity-5"
      style="background-image: radial-gradient(circle at 30% 50%, #00D4FF 0%, transparent 60%)">
    </div>
    <span class={`text-xs font-semibold px-2.5 py-0.5 rounded-full border ${badge.cls}`}>
      {badge.label}
    </span>
  </div>

  <div class="p-5 flex flex-col gap-3">
    <h2 class="font-display font-bold text-white text-lg leading-snug line-clamp-2
               group-hover:text-brand-cyan transition-colors">
      {title}
    </h2>

    <p class="text-brand-dim text-sm leading-relaxed line-clamp-2">
      {excerpt}
    </p>

    <!-- Rating -->
    {rating && (
      <div class="flex items-center gap-2">
        <span class="stars text-sm">{stars(rating)}</span>
        <span class="text-brand-cyan font-semibold text-sm">{rating}/10</span>
      </div>
    )}

    <!-- Footer -->
    <div class="flex items-center justify-between pt-1 mt-auto border-t border-brand-border/50">
      <span class="text-xs text-brand-dim">{dateFormatted}</span>
      <span class="text-xs font-medium text-brand-cyan group-hover:gap-2 transition-all flex items-center gap-1">
        Read more
        <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none"
          viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </span>
    </div>
  </div>
</a>
