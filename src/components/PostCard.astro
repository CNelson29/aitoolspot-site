---
interface Props {
  title:         string;
  slug:          string;
  excerpt:       string;
  date:          string;
  type:          string;
  rating?:       number;
  tags?:         string[];
  affiliate_link?: string;
  image?:        string;
}
const { title, slug, excerpt, date, type, rating, tags = [], image } = Astro.props;

const badge = {
  review:     { cls: 'badge-review',     label: 'Review' },
  comparison: { cls: 'badge-comparison', label: 'Comparison' },
  guide:      { cls: 'badge-guide',      label: 'Guide' },
  article:    { cls: 'badge-article',    label: 'Article' },
}[type] ?? { cls: 'badge-article', label: 'Article' };

const fallbackImage = `/images/posts/${slug}-hero.jpg`;
const cardImage = image || fallbackImage;
const topTag = tags[0]?.replaceAll('-', ' ') || badge.label;

function stars(r: number) {
  const full = Math.floor(r / 2);
  const half = r % 2 >= 1 ? 1 : 0;
  const empty = 5 - full - half;
  return '★'.repeat(full) + (half ? '⯨' : '') + '☆'.repeat(empty);
}

const dateFormatted = new Date(date).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});
---
<a href={`/${slug}/`} class="tool-card group block overflow-hidden no-underline">
  <div class="relative aspect-[16/10] overflow-hidden bg-brand-surface">
    <img
      src={cardImage}
      alt=""
      loading="lazy"
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-brand-bg via-brand-bg/42 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-brand-bg/72 via-transparent to-transparent"></div>

    <div class="absolute left-4 top-4 flex max-w-[calc(100%-2rem)] items-center gap-2">
      <span class={`text-[11px] font-semibold px-2.5 py-1 rounded-full border backdrop-blur ${badge.cls}`}>
        {badge.label}
      </span>
      <span class="truncate rounded-full border border-white/10 bg-black/35 px-2.5 py-1 text-[11px] font-semibold capitalize text-slate-200 backdrop-blur">
        {topTag}
      </span>
    </div>

    {rating && (
      <div class="absolute bottom-4 right-4 rounded-full border border-brand-cyan/30 bg-brand-bg/86 px-3 py-2 text-sm font-bold text-white shadow-lg backdrop-blur">
        <span class="text-brand-cyan">{rating}</span><span class="text-brand-dim">/10</span>
      </div>
    )}
  </div>

  <div class="flex min-h-[218px] flex-col gap-3 p-5">
    <div class="flex items-center justify-between gap-3 text-xs text-brand-dim">
      <span>{dateFormatted}</span>
      {rating && <span class="stars text-xs">{stars(rating)}</span>}
    </div>

    <h2 class="font-display text-lg font-bold leading-snug text-white line-clamp-2 transition-colors group-hover:text-brand-cyan">
      {title}
    </h2>

    <p class="text-sm leading-relaxed text-brand-dim line-clamp-3">
      {excerpt}
    </p>

    <div class="mt-auto flex items-center justify-between border-t border-brand-border/50 pt-3">
      <span class="text-xs font-semibold uppercase tracking-wide text-brand-dim">AIToolSpott</span>
      <span class="flex items-center gap-1 text-xs font-semibold text-brand-cyan transition-all group-hover:gap-2">
        Read guide
        <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none"
          viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </span>
    </div>
  </div>
</a>
