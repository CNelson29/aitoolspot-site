---
import Base from '../../../layouts/Base.astro';
---
<Base
  title="TikTok OAuth Callback | AIToolSpott"
  description="TikTok OAuth callback page for AIToolSpott."
  slug="api/tiktok/callback"
>
  <main class="mx-auto flex min-h-screen w-full max-w-3xl flex-col justify-center px-6 py-16">
    <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-wide text-sky-600">TikTok OAuth</p>
      <h1 class="mt-3 text-3xl font-bold text-slate-950">Authorization received</h1>
      <p class="mt-3 text-slate-700">
        This callback captures the TikTok authorization response for the AIToolSpott publisher workflow.
      </p>

      <label class="mt-6 block text-sm font-semibold text-slate-800" for="oauth-code">
        Authorization code
      </label>
      <textarea
        id="oauth-code"
        class="mt-2 h-28 w-full rounded-md border border-slate-300 bg-slate-50 p-3 font-mono text-sm text-slate-950"
        readonly
      ></textarea>

      <p id="oauth-state" class="mt-3 text-sm text-slate-500"></p>
      <p id="oauth-scopes" class="mt-2 text-sm text-slate-500"></p>
      <p id="oauth-error" class="mt-3 hidden rounded-md bg-red-50 p-3 text-sm text-red-700"></p>

      <code class="mt-6 block overflow-x-auto rounded-md bg-slate-950 p-4 text-sm text-slate-100">
        Exchange this code server-side with TikTok to obtain access and refresh tokens.
      </code>
    </section>
  </main>

  <script>
    const params = new URLSearchParams(window.location.search);
    const code = params.get('code') || '';
    const state = params.get('state') || '';
    const scopes = params.get('granted_scopes') || params.get('scope') || '';
    const error = params.get('error') || params.get('error_description') || '';
    const codeBox = document.getElementById('oauth-code');
    const stateBox = document.getElementById('oauth-state');
    const scopesBox = document.getElementById('oauth-scopes');
    const errorBox = document.getElementById('oauth-error');

    if (codeBox instanceof HTMLTextAreaElement) {
      codeBox.value = code;
    }
    if (stateBox) {
      stateBox.textContent = state ? `State: ${state}` : '';
    }
    if (scopesBox) {
      scopesBox.textContent = scopes ? `Scopes: ${scopes}` : '';
    }
    if (error && errorBox) {
      errorBox.classList.remove('hidden');
      errorBox.textContent = `TikTok returned an error: ${error}`;
    }
  </script>
</Base>
