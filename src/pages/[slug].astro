---
import Base   from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post }     = Astro.props;
const { data }     = post;
const { Content }  = await post.render();

const dateFormatted = new Date(data.date).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});

function stars(r: number) {
  return '★'.repeat(Math.floor(r / 2)) + (r % 2 >= 1 ? '⯨' : '') + '☆'.repeat(5 - Math.floor(r / 2) - (r % 2 >= 1 ? 1 : 0));
}

// Derive tool name from title (for schema)
const toolName = data.title.match(/^(.+?)\s+(Review|vs\s)/i)?.[1] ?? data.title.split(':')[0];

const badgeMap: Record<string, string> = {
  review: 'badge-review', comparison: 'badge-comparison',
  guide: 'badge-guide',   article: 'badge-article',
};
const badgeLabel: Record<string, string> = {
  review: 'Review', comparison: 'Comparison', guide: 'Guide', article: 'Article',
};
---
<Base
  title={`${data.title} | AIToolSpott`}
  description={data.excerpt}
  slug={data.slug || post.slug}
  type={data.type as any}
  rating={data.rating}
  toolName={toolName}
  date={data.date}
>
  <Header />

  <main class="flex-1">
    <!-- Article hero -->
    <div class={`grad-${data.type} border-b border-brand-border/50 py-12`}>
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-brand-dim mb-5">
          <a href="/" class="hover:text-brand-cyan transition-colors">Home</a>
          <span>›</span>
          <span class="text-brand-text">{data.category}</span>
        </nav>

        <!-- Badge + date -->
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-semibold px-2.5 py-0.5 rounded-full border ${badgeMap[data.type] || 'badge-article'}`}>
            {badgeLabel[data.type] || 'Article'}
          </span>
          <span class="text-brand-dim text-sm">{dateFormatted}</span>
        </div>

        <h1 class="font-display font-extrabold text-3xl sm:text-4xl text-white leading-tight mb-4">
          {data.title}
        </h1>

        <p class="text-brand-dim text-lg leading-relaxed mb-6">{data.excerpt}</p>

        <!-- Rating bar -->
        {data.rating && (
          <div class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.03] border border-brand-border inline-flex">
            <div>
              <div class="text-3xl font-display font-extrabold text-brand-cyan">{data.rating}<span class="text-lg text-brand-dim">/10</span></div>
              <div class="stars text-base mt-0.5">{stars(data.rating)}</div>
            </div>
            <div class="w-px h-10 bg-brand-border"></div>
            <div class="text-sm text-brand-text">
              <span class="font-semibold text-white">Our Rating</span><br/>
              <span class="text-brand-dim">{
                data.rating >= 9 ? 'Outstanding' :
                data.rating >= 8 ? 'Excellent' :
                data.rating >= 7 ? 'Good' :
                data.rating >= 5 ? 'Average' : 'Below average'
              }</span>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
      <!-- Affiliate CTA (top) -->
      {data.affiliate_link && data.affiliate_link !== 'https://aitoolspot.net' && (
        <div class="affiliate-box mb-8">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
              <p class="font-semibold text-white text-sm">Try {toolName} yourself</p>
              <p class="text-brand-dim text-xs mt-0.5">
                Affiliate link — we may earn a commission at no extra cost to you.
              </p>
            </div>
            <a
              href={data.affiliate_link}
              target="_blank" rel="noopener noreferrer sponsored"
              class="flex-shrink-0 px-5 py-2.5 rounded-lg bg-brand-cyan text-brand-bg font-semibold
                     text-sm hover:bg-sky-300 transition-colors whitespace-nowrap"
            >
              Try {toolName} →
            </a>
          </div>
        </div>
      )}

      <!-- Article body -->
      <article class="prose prose-invert max-w-none">
        <Content />
      </article>

      <!-- Tags -->
      {data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-brand-border/50">
          {data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}

      <!-- Affiliate CTA (bottom) -->
      {data.affiliate_link && data.affiliate_link !== 'https://aitoolspot.net' && (
        <div class="mt-8 p-6 rounded-2xl border border-brand-cyan/20 bg-gradient-to-br from-brand-surface to-brand-bg text-center">
          <p class="font-display font-bold text-xl text-white mb-2">
            Ready to try {toolName}?
          </p>
          <p class="text-brand-dim text-sm mb-4">
            Use our link to get the latest deals and support this channel.
          </p>
          <a
            href={data.affiliate_link}
            target="_blank" rel="noopener noreferrer sponsored"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-cyan text-brand-bg
                   font-semibold hover:bg-sky-300 transition-colors"
          >
            Get {toolName} →
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>
